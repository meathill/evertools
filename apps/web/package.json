{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run copy:pdf-worker && next dev",
    "build": "pnpm run copy:pdf-worker && next build",
    "preview": "pnpm run copy:pdf-worker && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm run copy:pdf-worker && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "copy:pdf-worker": "node -e \"const fs=require('node:fs'),path=require('node:path');const src=require.resolve('pdfjs-dist/build/pdf.worker.min.mjs');const dest=path.join('public','pdf','pdf.worker.min.mjs');fs.mkdirSync(path.dirname(dest),{recursive:true});fs.copyFileSync(src,dest);console.log('Copied pdf.worker.min.mjs ->',dest);\"",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@next/third-parties": "16.2.6",
    "@opennextjs/cloudflare": "^1.19.9",
    "@pdf-lib/fontkit": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "heic-to": "^1.5.2",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.5",
    "next": "16.2.6",
    "next-intl": "^4.11.2",
    "node-html-parser": "^7.1.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.4",
    "react-image-crop": "^11.1.2",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.86.0"
  }
}
